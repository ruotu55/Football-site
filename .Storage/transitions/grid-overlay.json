{
  "id": "grid-overlay",
  "name": "Grid Overlay",
  "description": "Animated grid of cells that covers the screen with staggered scaling",
  "options": {
    "rows": 8,
    "columns": 14,
    "cellColor": "#ff8cb3",
    "showDuration": 0.4,
    "hideDuration": 0.4,
    "showEase": "power3.inOut",
    "hideEase": "power2",
    "staggerEach": 0.03,
    "showTransformOrigin": "50% 0%",
    "hideTransformOrigin": "50% 100%"
  }
}
