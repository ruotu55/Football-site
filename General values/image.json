{
  "description": "Standard specification for team and asset images across the project",
  "version": "1.0",
  "size": {
    "width": 256,
    "height": 256,
    "unit": "px",
    "constraint": "exact"
  },
  "format": {
    "primary": "png",
    "allowed": ["png"],
    "compression": "lossless"
  },
  "background": {
    "type": "transparent",
    "alphaChannel": true
  },
  "color": {
    "mode": "RGBA",
    "bitDepth": 8,
    "colorProfile": "sRGB"
  },
  "constraints": {
    "maxFileSizeKb": 100,
    "minWidth": 256,
    "minHeight": 256,
    "aspectRatio": "1:1"
  },
  "usage": {
    "teamLogos": true,
    "nationalityFlags": false,
    "playerPhotos": true
  }
}
